{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["ticketKey", "phase", "timestamp", "gitState", "environment"],
  "properties": {
    "ticketKey": {
      "type": "string",
      "pattern": "^[A-Z]+-[0-9]+$",
      "description": "Jira-style ticket key (e.g., PROJ-123)"
    },
    "phase": {
      "type": "string",
      "enum": ["0", "1", "2", "3", "4", "5", "6"],
      "description": "Current phase number as string"
    },
    "completedPhases": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of completed phase identifiers"
    },
    "state": {
      "type": "object",
      "description": "Additional state data specific to the phase"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of checkpoint creation"
    },
    "gitState": {
      "type": "object",
      "required": ["commit", "branch"],
      "properties": {
        "commit": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$",
          "description": "Full Git commit SHA (40 characters)"
        },
        "branch": {
          "type": "string",
          "description": "Git branch name"
        },
        "hasUncommittedChanges": {
          "type": "boolean",
          "description": "Whether there were uncommitted changes at checkpoint time"
        }
      }
    },
    "environment": {
      "type": "object",
      "required": ["nodeVersion", "cwd"],
      "properties": {
        "nodeVersion": {
          "type": "string",
          "description": "Node.js version (e.g., v22.14.0)"
        },
        "pythonVersion": {
          "type": ["string", "null"],
          "description": "Python version if available (e.g., 3.9.0)"
        },
        "cwd": {
          "type": "string",
          "description": "Current working directory at checkpoint time"
        }
      }
    },
    "version": {
      "type": "string",
      "description": "Checkpoint format version"
    }
  }
}
