{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-agentic-framework/schemas/sdd-ticket.schema.json",
  "title": "SDD Ticket Schema",
  "description": "Canonical ticket format for Specification-Driven Development",
  "type": "object",
  "required": [
    "id",
    "source",
    "title",
    "userStory",
    "stakeholders",
    "acceptanceCriteria"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique ticket identifier (e.g., PROJ-123 or DRAFT-timestamp)",
      "pattern": "^[A-Z]+-[0-9]+$|^DRAFT-[0-9]{8}-[0-9]{6}$"
    },
    "source": {
      "type": "string",
      "enum": ["jira", "markdown", "input"],
      "description": "Origin of the ticket"
    },
    "sourcePath": {
      "type": "string",
      "description": "Full path or URL to original source"
    },
    "title": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200,
      "description": "Concise ticket title"
    },
    "userStory": {
      "type": "object",
      "required": ["role", "goal", "benefit"],
      "properties": {
        "role": {
          "type": ["string", "null"],
          "description": "User role or persona (As a...)"
        },
        "goal": {
          "type": ["string", "null"],
          "description": "User goal or capability (I want...)"
        },
        "benefit": {
          "type": ["string", "null"],
          "description": "Business value or outcome (So that...)"
        }
      }
    },
    "stakeholders": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role", "name", "responsibility"],
        "properties": {
          "role": {
            "type": "string",
            "description": "Stakeholder role (Requester, Product Owner, etc.)"
          },
          "name": {
            "type": "string",
            "description": "Stakeholder name"
          },
          "responsibility": {
            "type": "string",
            "description": "What they're responsible for"
          }
        }
      }
    },
    "successCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 10
      },
      "description": "Measurable success outcomes"
    },
    "metrics": {
      "type": ["string", "null"],
      "description": "How success will be measured"
    },
    "acceptanceCriteria": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["scenario", "given", "when", "then"],
        "properties": {
          "scenario": {
            "type": "string",
            "description": "Scenario name"
          },
          "given": {
            "type": "string",
            "description": "Initial context/state"
          },
          "and_given": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Additional context"
          },
          "when": {
            "type": "string",
            "description": "Action/trigger"
          },
          "then": {
            "type": "string",
            "description": "Expected outcome"
          },
          "and_then": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Additional outcomes"
          }
        }
      },
      "description": "BDD scenarios in Given-When-Then format"
    },
    "technicalContext": {
      "type": "object",
      "properties": {
        "currentState": {
          "type": "array",
          "items": { "type": "string" },
          "description": "What exists today"
        },
        "proposedChanges": {
          "type": "array",
          "items": { "type": "string" },
          "description": "What will be built/modified"
        },
        "constraints": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Performance, security, scalability requirements"
        },
        "integrationPoints": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Systems to integrate with"
        },
        "architectureDecisions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "decision": { "type": "string" },
              "rationale": { "type": "string" }
            }
          },
          "description": "Key technical choices and rationale"
        }
      }
    },
    "outOfScope": {
      "type": "array",
      "items": { "type": "string" },
      "description": "What is explicitly NOT included"
    },
    "futureConsiderations": {
      "type": ["string", "null"],
      "description": "What might be addressed later"
    },
    "edgeCases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["case", "handling"],
        "properties": {
          "case": { "type": "string" },
          "handling": { "type": "string" }
        }
      },
      "description": "Edge cases and how to handle them"
    },
    "errorScenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["error", "userMessage", "systemBehavior"],
        "properties": {
          "error": { "type": "string" },
          "userMessage": { "type": "string" },
          "systemBehavior": { "type": "string" }
        }
      },
      "description": "Error scenarios and handling"
    },
    "validationRules": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Data validation rules"
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "blocking": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tickets that must complete first"
        },
        "related": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Related tickets"
        }
      }
    },
    "definitionOfDone": {
      "type": "object",
      "required": ["codeQuality", "testing", "documentation", "review"],
      "properties": {
        "codeQuality": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Code quality requirements"
        },
        "testing": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Testing requirements"
        },
        "documentation": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Documentation requirements"
        },
        "review": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Review and deployment requirements"
        }
      }
    },
    "implementationNotes": {
      "type": ["string", "null"],
      "description": "Additional context for implementer"
    },
    "references": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Links to designs, docs, etc."
    },
    "metadata": {
      "type": "object",
      "properties": {
        "priority": {
          "type": ["string", "null"],
          "enum": ["High", "Medium", "Low", null]
        },
        "labels": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sprint": {
          "type": ["string", "null"]
        },
        "epic": {
          "type": ["string", "null"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "investValidated": {
          "type": "boolean",
          "description": "Whether INVEST criteria validated"
        },
        "bddScenarioCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
