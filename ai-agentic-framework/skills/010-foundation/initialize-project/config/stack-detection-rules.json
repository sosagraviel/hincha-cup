{
  "$schema": "stack-detection-rules.schema.json",
  "version": "2.0.0",
  "description": "Deterministic stack detection rules - NO AI interpretation allowed. Rules DETECT technologies, they don't RESTRICT them. Unknown technologies fallback to Phase 1 agent findings.",

  "_design_notes": {
    "purpose": "These rules provide deterministic detection for KNOWN technologies. Technologies not listed here are detected via Phase 1 agents and their findings are trusted.",
    "fallback_behavior": "If a technology is not in these rules, use the `languages`, `frameworks`, `databases` etc. from the consolidated Phase 1 analysis.",
    "extensibility": "This file can grow over time as new technologies become common, but the system works for ANY technology via fallback."
  },

