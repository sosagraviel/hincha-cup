{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "private": true,
  "engines": {
    "node": ">=22.14.x",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.2.1",
  "scripts": {
    "build": "pnpm --filter @livonit/shared build && nest build",
    "start:prod": "NODE_OPTIONS=\"--require reflect-metadata\" node dist/main",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint:check": "eslint --max-warnings=0",
    "lint:fix": "eslint --fix --max-warnings=0",
    "type:check": "tsc -p tsconfig.json  --noEmit",
    "type:check:watch": "tsc -p tsconfig.json --watch --noEmit",
    "test:unit": "NODE_ENV=testing NODE_OPTIONS=--experimental-vm-modules jest --detectOpenHandles --runInBand",
    "test:integration": "NODE_ENV=testing NODE_OPTIONS=--experimental-vm-modules jest --config ./jest.e2e.config.mjs --detectOpenHandles --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "typeorm:migration:create": "npx ts-node src/libs/dbMigrations/createMigration.ts migration -- ",
    "typeorm:seed:create": "npx ts-node src/libs/dbMigrations/createMigration.ts seed -- ",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject ./dist && sentry-cli sourcemaps upload ./dist"
  },
  "dependencies": {
    "@keycloak/keycloak-admin-client": "^26.1.4",
    "@livonit/shared": "workspace:^",
    "@nestjs/bullmq": "^10.1.0",
    "@nestjs/common": "^11.0.11",
    "@nestjs/config": "^4.0.1",
    "@nestjs/core": "^11.0.11",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/microservices": "^11.0.11",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.11",
    "@nestjs/platform-socket.io": "^11.0.11",
    "@nestjs/swagger": "^11.0.6",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.0.11",
    "@sentry/nestjs": "^9.30.0",
    "@types/jsonwebtoken": "^9.0.9",
    "argon2": "^0.41.1",
    "axios": "^1.9.0",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "email-validator": "^2.0.4",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.2.0",
    "nanoid": "3.3.4",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.14.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1",
    "typeorm": "^0.3.21"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@nestjs/cli": "^11.0.5",
    "@nestjs/schematics": "^11.0.2",
    "@nestjs/testing": "^11.0.11",
    "@sentry/cli": "^2.46.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "babel-jest": "^30.0.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "socket.io-client": "^4.8.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "tsc-files": "^1.1.4",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.0.0"
  }
}
