import request from 'supertest';
// Removed test-app imports - using direct HTTP requests
import { getAccessToken, TEST_USERS } from '../helpers/auth';



describe('Chat API (e2e)', () => {
  let aliceToken: string;
  let bobToken: string;
  let _carolToken: string;

  let acmeId: string;
  let _aliceUserId: string;
  let bobUserId: string;
  let roomId: string;
  let messageId: string;
  let dmThreadId: string;

  beforeAll(async () => {
    app = await getTestApp();
    [aliceToken, bobToken, _carolToken] = await Promise.all([
      getAccessToken(TEST_USERS.alice.email, TEST_USERS.alice.password),
      getAccessToken(TEST_USERS.bob.email, TEST_USERS.bob.password),
      getAccessToken(TEST_USERS.carol.email, TEST_USERS.carol.password)
    ]);

    // Discover user IDs and org ID
    const [aliceRes, bobRes] = await Promise.all([
      request(app.getHttpServer())
        .get(`${API}/users/me`)
        .set('Authorization', `Bearer ${aliceToken}`),
      request(app.getHttpServer())
        .get(`${API}/users/me`)
        .set('Authorization', `Bearer ${bobToken}`)
    ]);

    _aliceUserId = aliceRes.body.id;
    bobUserId = bobRes.body.id;

    const orgs = await httpClient
      .get(`${API}/organizations`)
      .set('Authorization', `Bearer ${aliceToken}`);
    acmeId = orgs.body.find((o: any) => o.slug === 'acme').id;
  });

  afterAll(async () => {
    await closeTestApp();
  });

  // ====== Chat Rooms ======

  describe('POST /chat/rooms', () => {
    it('should create a chat room', async () => {
      const res = await httpClient
        .post(`${API}/chat/rooms`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .send({
          name: 'E2E General Chat',
          organizationId: acmeId,
          description: 'Created by e2e test',
          isPublic: true
        })
        .expect(201);

      expect(res.body).toHaveProperty('id');
      expect(res.body.name).toBe('E2E General Chat');
      roomId = res.body.id;
    });
  });

  describe('GET /chat/rooms', () => {
    it('should list rooms for organization', async () => {
      const res = await httpClient
        .get(`${API}/chat/rooms?organizationId=${acmeId}`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .expect(200);

      expect(Array.isArray(res.body)).toBe(true);
      expect(res.body.some((r: any) => r.id === roomId)).toBe(true);
    });
  });

  describe('GET /chat/rooms/:id', () => {
    it('should return room details', async () => {
      const res = await httpClient
        .get(`${API}/chat/rooms/${roomId}`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .expect(200);

      expect(res.body.id).toBe(roomId);
      expect(res.body.name).toBe('E2E General Chat');
    });
  });

  // ====== Messages ======

  describe('POST /chat/messages', () => {
    it('should send a message to a room', async () => {
      const res = await httpClient
        .post(`${API}/chat/messages`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .send({ content: 'Hello from e2e!', roomId })
        .expect(201);

      expect(res.body).toHaveProperty('id');
      expect(res.body.content).toBe('Hello from e2e!');
      messageId = res.body.id;
    });

    it('should send another message from a different user', async () => {
      const res = await httpClient
        .post(`${API}/chat/messages`)
        .set('Authorization', `Bearer ${bobToken}`)
        .send({ content: 'Hey Alice!', roomId })
        .expect(201);

      expect(res.body.content).toBe('Hey Alice!');
    });
  });

  describe('GET /chat/rooms/:id/messages', () => {
    it('should return room messages', async () => {
      const res = await httpClient
        .get(`${API}/chat/rooms/${roomId}/messages`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .expect(200);

      expect(Array.isArray(res.body)).toBe(true);
      expect(res.body.length).toBeGreaterThanOrEqual(2);
    });

    it('should support limit parameter', async () => {
      const res = await httpClient
        .get(`${API}/chat/rooms/${roomId}/messages?limit=1`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .expect(200);

      expect(res.body).toHaveLength(1);
    });
  });

  // ====== Read Receipts ======

  describe('POST /chat/messages/:id/read', () => {
    it('should mark message as read', async () => {
      await httpClient
        .post(`${API}/chat/messages/${messageId}/read`)
        .set('Authorization', `Bearer ${bobToken}`)
        .expect(201);
    });
  });

  // ====== DM Threads ======

  describe('POST /chat/dms', () => {
    it('should start a DM thread', async () => {
      const res = await httpClient
        .post(`${API}/chat/dms`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .send({ otherUserId: bobUserId })
        .expect(201);

      expect(res.body).toHaveProperty('id');
      dmThreadId = res.body.id;
    });

    it('should return existing thread if already exists', async () => {
      const res = await httpClient
        .post(`${API}/chat/dms`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .send({ otherUserId: bobUserId })
        .expect(201);

      expect(res.body.id).toBe(dmThreadId);
    });
  });

  describe('GET /chat/dms', () => {
    it('should list user DM threads', async () => {
      const res = await httpClient
        .get(`${API}/chat/dms`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .expect(200);

      expect(Array.isArray(res.body)).toBe(true);
      expect(res.body.some((dm: any) => dm.id === dmThreadId)).toBe(true);
    });
  });

  describe('GET /chat/dms/:id/messages', () => {
    it('should send and retrieve DM messages', async () => {
      // Send a DM
      await httpClient
        .post(`${API}/chat/messages`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .send({ content: 'Hey Bob, DM test!', dmThreadId })
        .expect(201);

      // Get DM messages
      const res = await httpClient
        .get(`${API}/chat/dms/${dmThreadId}/messages`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .expect(200);

      expect(Array.isArray(res.body)).toBe(true);
      expect(res.body.length).toBeGreaterThanOrEqual(1);
    });
  });

  // ====== Message Deletion ======

  describe('DELETE /chat/messages/:id', () => {
    it('should reject deletion by non-author with 403', async () => {
      // Bob tries to delete Alice's message — returns 403 Forbidden
      await httpClient
        .delete(`${API}/chat/messages/${messageId}`)
        .set('Authorization', `Bearer ${bobToken}`)
        .expect(403);
    });

    it('should allow author to delete own message', async () => {
      await httpClient
        .delete(`${API}/chat/messages/${messageId}`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .expect(200);
    });

    it('should return 404 when deleting non-existent message', async () => {
      await httpClient
        .delete(`${API}/chat/messages/00000000-0000-0000-0000-000000000000`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .expect(404);
    });
  });

  describe('GET /chat/rooms/:id (edge cases)', () => {
    it('should return 404 for non-existent room', async () => {
      await httpClient
        .get(`${API}/chat/rooms/00000000-0000-0000-0000-000000000000`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .expect(404);
    });
  });

  describe('POST /chat/rooms (validation)', () => {
    it('should return 400 when name is missing', async () => {
      await httpClient
        .post(`${API}/chat/rooms`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .send({ organizationId: acmeId })
        .expect(400);
    });

    it('should return 400 when organizationId is missing', async () => {
      await httpClient
        .post(`${API}/chat/rooms`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .send({ name: 'Missing Org Room' })
        .expect(400);
    });
  });

  describe('POST /chat/messages (validation)', () => {
    it('should return 400 when content is missing', async () => {
      await httpClient
        .post(`${API}/chat/messages`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .send({ roomId })
        .expect(400);
    });
  });
});
