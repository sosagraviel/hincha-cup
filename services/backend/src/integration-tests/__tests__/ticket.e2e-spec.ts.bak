import request from 'supertest';
// Removed test-app imports - using direct HTTP requests
import { getAccessToken, TEST_USERS } from '../helpers/auth';



describe('Ticket & Comment API (e2e)', () => {
  let aliceToken: string;
  let bobToken: string;
  let carolToken: string;

  let acmeId: string;
  let pltProjectId: string;
  let existingTicketId: string;
  let createdTicketId: string;

  beforeAll(async () => {
    app = await getTestApp();
    [aliceToken, bobToken, carolToken] = await Promise.all([
      getAccessToken(TEST_USERS.alice.email, TEST_USERS.alice.password),
      getAccessToken(TEST_USERS.bob.email, TEST_USERS.bob.password),
      getAccessToken(TEST_USERS.carol.email, TEST_USERS.carol.password)
    ]);

    // Discover org + project IDs
    const orgs = await httpClient
      .get(`${API}/organizations`)
      .set('Authorization', `Bearer ${aliceToken}`);
    acmeId = orgs.body.find((o: any) => o.slug === 'acme').id;

    const projects = await httpClient
      .get(`${API}/organizations/${acmeId}/projects`)
      .set('Authorization', `Bearer ${aliceToken}`);
    pltProjectId = projects.body.find((p: any) => p.key === 'PLT').id;
  });

  afterAll(async () => {
    await closeTestApp();
  });

  // ====== Board ======

  describe('GET /projects/:projectId/board', () => {
    it('should return board as a status-keyed object with ticket arrays', async () => {
      const res = await httpClient
        .get(`${API}/projects/${pltProjectId}/board`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .expect(200);

      // Board is Record<string, Ticket[]> keyed by status
      expect(typeof res.body).toBe('object');
      expect(Array.isArray(res.body)).toBe(false);

      const expectedStatuses = [
        'backlog',
        'todo',
        'in_progress',
        'in_review',
        'done'
      ];
      for (const status of expectedStatuses) {
        expect(res.body).toHaveProperty(status);
        expect(Array.isArray(res.body[status])).toBe(true);
      }

      // Find a ticket to use in later tests
      for (const status of expectedStatuses) {
        if (res.body[status].length > 0) {
          existingTicketId = res.body[status][0].id;
          break;
        }
      }

      expect(existingTicketId).toBeDefined();
    });

    it('should return 403 for non-project-member', async () => {
      await httpClient
        .get(`${API}/projects/${pltProjectId}/board`)
        .set('Authorization', `Bearer ${carolToken}`)
        .expect(403);
    });
  });

  // ====== Ticket List ======

  describe('GET /projects/:projectId/tickets', () => {
    it('should list tickets with pagination', async () => {
      const res = await httpClient
        .get(`${API}/projects/${pltProjectId}/tickets?page=1&limit=5`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .expect(200);

      expect(res.body).toHaveProperty('data');
      expect(res.body).toHaveProperty('meta');
      expect(Array.isArray(res.body.data)).toBe(true);
      expect(res.body.meta.page).toBe(1);
    });
  });

  // ====== Ticket CRUD ======

  describe('POST /projects/:projectId/tickets', () => {
    it('should create a ticket as project member', async () => {
      const res = await httpClient
        .post(`${API}/projects/${pltProjectId}/tickets`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .send({
          title: 'E2E Test Ticket',
          description: 'Created by integration test',
          priority: 'medium',
          status: 'backlog'
        })
        .expect(201);

      expect(res.body).toHaveProperty('id');
      expect(res.body.title).toBe('E2E Test Ticket');
      expect(res.body.priority).toBe('medium');
      createdTicketId = res.body.id;
    });

    it('should reject ticket creation by non-project-member', async () => {
      await httpClient
        .post(`${API}/projects/${pltProjectId}/tickets`)
        .set('Authorization', `Bearer ${carolToken}`)
        .send({
          title: 'Unauthorized Ticket',
          priority: 'low'
        })
        .expect(403);
    });

    it('should return 400 when title is missing', async () => {
      await httpClient
        .post(`${API}/projects/${pltProjectId}/tickets`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .send({ priority: 'low' })
        .expect(400);
    });

    it('should return 400 when priority value is invalid', async () => {
      await httpClient
        .post(`${API}/projects/${pltProjectId}/tickets`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .send({ title: 'Bad Priority', priority: 'super_urgent' })
        .expect(400);
    });
  });

  describe('GET /tickets/:id', () => {
    it('should return ticket details', async () => {
      const res = await httpClient
        .get(`${API}/tickets/${createdTicketId}`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .expect(200);

      expect(res.body.id).toBe(createdTicketId);
      expect(res.body.title).toBe('E2E Test Ticket');
    });

    it('should return 404 for non-existent ticket', async () => {
      await httpClient
        .get(`${API}/tickets/00000000-0000-0000-0000-000000000000`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .expect(404);
    });
  });

  describe('PATCH /tickets/:id', () => {
    it('should update ticket details', async () => {
      const res = await httpClient
        .patch(`${API}/tickets/${createdTicketId}`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .send({ title: 'E2E Ticket Updated', priority: 'high' })
        .expect(200);

      expect(res.body.title).toBe('E2E Ticket Updated');
      expect(res.body.priority).toBe('high');
    });
  });

  describe('PATCH /tickets/:id/status (move)', () => {
    it('should move ticket to a new status', async () => {
      const res = await httpClient
        .patch(`${API}/tickets/${createdTicketId}/status`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .send({ status: 'todo', order: 0 })
        .expect(200);

      expect(res.body.status).toBe('todo');
    });

    it('should return 400 when status value is invalid', async () => {
      await httpClient
        .patch(`${API}/tickets/${createdTicketId}/status`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .send({ status: 'flying', order: 0 })
        .expect(400);
    });
  });

  // ====== Comments ======

  describe('POST /tickets/:ticketId/comments', () => {
    let commentId: string;

    it('should add a comment to a ticket', async () => {
      const res = await httpClient
        .post(`${API}/tickets/${existingTicketId}/comments`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .send({ content: 'E2E test comment' })
        .expect(201);

      expect(res.body).toHaveProperty('id');
      expect(res.body.content).toBe('E2E test comment');
      commentId = res.body.id;
    });

    it('should return 400 when comment content is empty', async () => {
      await httpClient
        .post(`${API}/tickets/${existingTicketId}/comments`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .send({ content: '' })
        .expect(400);
    });

    it('should return 400 when comment content is missing', async () => {
      await httpClient
        .post(`${API}/tickets/${existingTicketId}/comments`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .send({})
        .expect(400);
    });

    it('should return 404 when commenting on non-existent ticket', async () => {
      await httpClient
        .post(`${API}/tickets/00000000-0000-0000-0000-000000000000/comments`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .send({ content: 'Ghost comment' })
        .expect(404);
    });

    it('should update own comment', async () => {
      const res = await httpClient
        .patch(`${API}/comments/${commentId}`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .send({ content: 'E2E comment updated' })
        .expect(200);

      expect(res.body.content).toBe('E2E comment updated');
    });

    it("should reject updating another user's comment", async () => {
      // Bob tries to update Alice's comment
      await httpClient
        .patch(`${API}/comments/${commentId}`)
        .set('Authorization', `Bearer ${bobToken}`)
        .send({ content: 'Hijacked!' })
        .expect(403);
    });

    it("should reject deleting another user's comment", async () => {
      await httpClient
        .delete(`${API}/comments/${commentId}`)
        .set('Authorization', `Bearer ${bobToken}`)
        .expect(403);
    });

    it('should delete own comment', async () => {
      await httpClient
        .delete(`${API}/comments/${commentId}`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .expect(200);
    });
  });

  // ====== Delete Ticket ======

  describe('DELETE /tickets/:id', () => {
    it('should reject deletion by non-admin project member', async () => {
      // Bob is member in PLT (not admin)
      await httpClient
        .delete(`${API}/tickets/${createdTicketId}`)
        .set('Authorization', `Bearer ${bobToken}`)
        .expect(403);
    });

    it('should allow project admin to delete ticket', async () => {
      // Alice is admin in PLT
      await httpClient
        .delete(`${API}/tickets/${createdTicketId}`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .expect(200);
    });
  });
});
