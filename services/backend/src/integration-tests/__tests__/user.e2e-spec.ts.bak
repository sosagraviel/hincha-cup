import { httpClient } from '../helpers/http-client';
import { getAccessToken, TEST_USERS } from '../helpers/auth';

describe('User API (e2e)', () => {
  let adminToken: string;
  let aliceToken: string;

  beforeAll(async () => {
    [adminToken, aliceToken] = await Promise.all([
      getAccessToken(TEST_USERS.admin.email, TEST_USERS.admin.password),
      getAccessToken(TEST_USERS.alice.email, TEST_USERS.alice.password)
    ]);
  });

  describe('GET /users/me', () => {
    it('should return current user profile for admin', async () => {
      const res = await httpClient.get('/users/me', {
        headers: { Authorization: `Bearer ${adminToken}` }
      });

      expect(res.status).toBe(200);
      expect(res.data).toMatchObject({
        email: 'admin@gira.com',
        fullName: 'Admin User',
        status: 'active'
      });
      expect(res.data).toHaveProperty('id');
      expect(res.data).toHaveProperty('externalId');
    });

    it('should return current user profile for alice', async () => {
      const res = await httpClient.get('/users/me', {
        headers: { Authorization: `Bearer ${aliceToken}` }
      });

      expect(res.status).toBe(200);
      expect(res.data).toMatchObject({
        email: 'alice@acme.com',
        fullName: 'Alice Johnson'
      });
    });

    it('should return 401 without auth token', async () => {
      const res = await httpClient.get('/users/me');
      expect(res.status).toBe(401);
    });

    it('should return 401 with invalid token', async () => {
      const res = await httpClient.get('/users/me', {
        headers: { Authorization: 'Bearer invalid-token' }
      });
      expect(res.status).toBe(401);
    });
  });

  describe('PATCH /users/me', () => {
    it('should update current user fullName', async () => {
      const res = await httpClient.patch('/users/me',
        { fullName: 'Alice J. Updated' },
        { headers: { Authorization: `Bearer ${aliceToken}` } }
      );

      expect(res.status).toBe(200);
      expect(res.data.fullName).toBe('Alice J. Updated');

      // Restore original name
      const restore = await httpClient.patch('/users/me',
        { fullName: 'Alice Johnson' },
        { headers: { Authorization: `Bearer ${aliceToken}` } }
      );
      expect(restore.status).toBe(200);
    });

    it('should reject unknown fields', async () => {
      await httpClient
        .patch(`${API}/users/me`)
        .set('Authorization', `Bearer ${aliceToken}`)
        .send({ email: 'hacker@evil.com' })
        .expect(400);
    });
  });
});
