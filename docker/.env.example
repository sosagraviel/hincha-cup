# Vite env for Docker dev — API key must look like a real Firebase key (AIzaSy...)
VITE_FIREBASE_API_KEY=AIzaSyDEMO_KEY_FOR_EMULATORS_ONLY
VITE_FIREBASE_AUTH_DOMAIN=gritogol.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=gritogol
VITE_FIREBASE_STORAGE_BUCKET=gritogol.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:demo000000000000
VITE_USE_EMULATORS=true
