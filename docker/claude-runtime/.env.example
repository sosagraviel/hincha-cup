# Claude Code Runtime Environment Variables
# Copy this file to .env and fill in your actual values

# =============================================================================
# PROJECT CONFIGURATION
# =============================================================================

# Path to the project you want Claude to work on (absolute path)
PROJECT_PATH=/Users/your-username/projects/your-project

# =============================================================================
# CLAUDE API
# =============================================================================

# Your Claude API key from https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-api03-...

# =============================================================================
# MCP SERVERS - ATLASSIAN (JIRA + CONFLUENCE)
# =============================================================================

# Atlassian Cloud ID (get from https://api.atlassian.com/oauth/token/accessible-resources)
ATLASSIAN_CLOUD_ID=your-cloud-id-here

# Your Atlassian email
ATLASSIAN_USER_EMAIL=you@company.com

# Atlassian site URL
ATLASSIAN_SITE_URL=https://your-company.atlassian.net

# API token from https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_API_TOKEN=ATATT3xFfGF0...

# =============================================================================
# MCP SERVERS - GITHUB
# =============================================================================

# GitHub Personal Access Token from https://github.com/settings/tokens/new
# Required scopes: repo, read:org, read:user, workflow
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_xxxxxxxxxxxx

# =============================================================================
# MCP SERVERS - GOOGLE SHEETS (OPTIONAL)
# =============================================================================

# Path to Google OAuth2 credentials file
GOOGLE_SHEETS_CREDENTIALS=/root/.config/google-sheets/credentials.json

# Path to Google OAuth2 token file
GOOGLE_SHEETS_TOKEN=/root/.config/google-sheets/token.json

# =============================================================================
# MCP SERVERS - NOTION (OPTIONAL)
# =============================================================================

# Notion Integration token from https://www.notion.so/my-integrations
NOTION_API_KEY=secret_xxxxxxxxxxxx

# =============================================================================
# DATABASE CONNECTIONS (PROJECT-SPECIFIC)
# =============================================================================

# PostgreSQL connection string (if project uses PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/database_name

# Redis connection string (if project uses Redis)
REDIS_URL=redis://localhost:6379

# =============================================================================
# AWS CREDENTIALS (OPTIONAL, IF PROJECT USES AWS)
# =============================================================================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# =============================================================================
# GCP CREDENTIALS (OPTIONAL, IF PROJECT USES GCP)
# =============================================================================

GOOGLE_APPLICATION_CREDENTIALS=/root/.config/gcp/service-account.json
GCP_PROJECT_ID=

# =============================================================================
# FIREBASE CREDENTIALS (OPTIONAL, IF PROJECT USES FIREBASE)
# =============================================================================

FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# =============================================================================
# OTHER SETTINGS
# =============================================================================

# Node environment
NODE_ENV=development

# Timezone (optional)
TZ=America/New_York
