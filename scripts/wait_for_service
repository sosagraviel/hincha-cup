#!/usr/bin/env bash

FILE_DIR=$(dirname $(readlink -f $(which "$0")))
source $FILE_DIR/print.sh

set -euo pipefail

SERVICE_URL="${1:-}"
MAX_RETRIES="${2:-20}"
RETRY_INTERVAL="${3:-5}"
RETRY_MESSAGE="${4:-Service not ready}"

if [ -z "$SERVICE_URL" ]; then
  error "SERVICE_URL is required as the first argument" >&2
  exit 1
fi

HTTP_CODE="000"
for i in $(seq 1 "$MAX_RETRIES"); do
  HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" "$SERVICE_URL" || true)
  if [ "$HTTP_CODE" -eq 200 ] 2>/dev/null; then
    success "Service is up and running!"
    exit 0
  else
    warn "$RETRY_MESSAGE (HTTP status: $HTTP_CODE). Retrying in $RETRY_INTERVAL seconds..."
    sleep "$RETRY_INTERVAL"
  fi
done

error "Service did not become available within the retry limit."
exit 1 