# =============================================================
# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit your .env file to version control
# =============================================================

# --------------------------
# Application Under Test
# Required — points tests to the correct environment
# --------------------------
APP_BASE_URL=https://your-app-url.com

# --------------------------
# Browser Configuration
# --------------------------
TEST_BROWSER=chromium

# --------------------------
# AI Provider
# --------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key-here
MODEL_TIER=sonnet

# =============================================================
# The following variables are only needed when MCP connections
# are NOT configured. If MCP is set up, authentication is
# handled automatically and these can be ignored.
# =============================================================

# --------------------------
# Qase Test Management (non-MCP fallback)
# --------------------------
QASE_TESTOPS_API_TOKEN=your-qase-token-here
QASE_PROJECT_CODE=your-project-code
QASE_MODE=testops
QASE_API=https://api.qase.io/v1

# --------------------------
# Linear Integration (non-MCP fallback)
# --------------------------
LINEAR_API_KEY=your-linear-api-key-here

# --------------------------
# Jira Integration (non-MCP fallback)
# --------------------------
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USERNAME=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token-here
JIRA_PROJECT_KEY=your-project-key

# --------------------------
# TestRail Integration (non-MCP fallback)
# --------------------------
TESTRAIL_BASE_URL=https://your-org.testrail.io
TESTRAIL_USERNAME=your-email@company.com
TESTRAIL_API_KEY=your-testrail-api-key-here
TESTRAIL_PROJECT_ID=your-project-id
