{
  "description": "Claude Code settings template for initialize-project skill with validation hooks",
  "version": "2.0.0",
  "hooks": {
    "SubagentStop": [
      {
        "description": "Validate analyzer agent outputs",
        "matcher": {
          "agentName": [
            "structure-architecture-analyzer",
            "tech-stack-dependencies-analyzer",
            "code-patterns-testing-analyzer",
            "data-flows-integrations-analyzer"
          ]
        },
        "command": "python3 .claude/skills/initialize-project/hooks/validate-subagent-output.py",
        "stdin": "agentOutput",
        "enabled": true
      }
    ],
    "TaskCompleted": [
      {
        "description": "Validate phase 1 completion",
        "matcher": {
          "taskDescription": "Phase 1: Parallel Analysis"
        },
        "command": "PROJECT_PATH={{project_path}} CURRENT_PHASE=1 python3 .claude/skills/initialize-project/hooks/validate-phase-completion.py",
        "enabled": true
      },
      {
        "description": "Validate phase 2 completion",
        "matcher": {
          "taskDescription": "Phase 2: Consolidation"
        },
        "command": "PROJECT_PATH={{project_path}} CURRENT_PHASE=2 python3 .claude/skills/initialize-project/hooks/validate-phase-completion.py",
        "enabled": true
      },
      {
        "description": "Validate phase 3 completion",
        "matcher": {
          "taskDescription": "Phase 3: Opus Synthesis"
        },
        "command": "PROJECT_PATH={{project_path}} CURRENT_PHASE=3 python3 .claude/skills/initialize-project/hooks/validate-phase-completion.py",
        "enabled": true
      },
      {
        "description": "Validate phase 4 completion",
        "matcher": {
          "taskDescription": "Phase 4: File Writing"
        },
        "command": "PROJECT_PATH={{project_path}} CURRENT_PHASE=4 python3 .claude/skills/initialize-project/hooks/validate-phase-completion.py",
        "enabled": true
      },
      {
        "description": "Validate phase 5 completion",
        "matcher": {
          "taskDescription": "Phase 5: Resource Copying"
        },
        "command": "PROJECT_PATH={{project_path}} CURRENT_PHASE=5 python3 .claude/skills/initialize-project/hooks/validate-phase-completion.py",
        "enabled": true
      }
    ],
    "Stop": [
      {
        "description": "Final state validation and metrics logging",
        "matcher": {
          "skillName": "initialize-project"
        },
        "command": "PROJECT_PATH={{project_path}} python3 .claude/skills/initialize-project/hooks/validate-final-state.py",
        "enabled": true
      }
    ]
  },
  "notes": {
    "hook_exit_codes": {
      "0": "Validation passed, allow continuation",
      "2": "Validation failed, block continuation (SubagentStop and TaskCompleted hooks only)",
      "other": "Error, treat as validation failure"
    },
    "variables": {
      "{{project_path}}": "Automatically replaced with the current project path"
    },
    "installation": [
      "1. Copy this file to PROJECT_ROOT/.claude/settings.json",
      "2. Update {{project_path}} variable if needed",
      "3. Ensure Python 3 is installed and available",
      "4. Make hook scripts executable: chmod +x hooks/*.py"
    ],
    "testing": [
      "Test hooks manually:",
      "  echo '{...json...}' | python3 hooks/validate-subagent-output.py",
      "  PROJECT_PATH=/path CURRENT_PHASE=1 python3 hooks/validate-phase-completion.py",
      "  PROJECT_PATH=/path python3 hooks/validate-final-state.py"
    ]
  }
}
