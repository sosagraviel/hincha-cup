{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Question Consolidation Output Schema",
  "description": "Schema for validating question consolidation agent output",
  "type": "object",
  "required": ["consolidated_gaps", "consolidation_metadata"],
  "additionalProperties": false,
  "properties": {
    "consolidated_gaps": {
      "type": "array",
      "description": "Array of consolidated gap questions",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": ["item", "question", "reason", "priority"],
        "additionalProperties": false,
        "properties": {
          "item": {
            "type": "string",
            "minLength": 3,
            "maxLength": 100,
            "description": "Short descriptive name for the gap topic"
          },
          "question": {
            "type": "string",
            "minLength": 10,
            "maxLength": 500,
            "pattern": ".*\\?$",
            "description": "Clear, actionable question ending with ?"
          },
          "reason": {
            "type": "string",
            "minLength": 10,
            "maxLength": 1000,
            "description": "Combined context from all relevant agents"
          },
          "priority": {
            "type": "string",
            "enum": ["high", "medium", "low"],
            "description": "Highest priority from constituent gaps"
          },
          "type": {
            "type": "string",
            "enum": ["needs_verification", "sparse_findings", "missing_language_coverage"],
            "description": "Type of gap (inherited from source)"
          },
          "consolidated_from": {
            "type": "array",
            "description": "List of source agent names",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "01-structure-architecture",
                "02-tech-stack-dependencies",
                "03-code-patterns-testing",
                "04-data-flows-integrations",
                "consolidation"
              ]
            }
          },
          "original_count": {
            "type": "integer",
            "minimum": 1,
            "description": "Number of original gaps consolidated into this one"
          }
        }
      }
    },
    "consolidation_metadata": {
      "type": "object",
      "required": [
        "original_gap_count",
        "consolidated_gap_count",
        "reduction_percentage",
        "consolidation_groups"
      ],
      "additionalProperties": false,
      "properties": {
        "original_gap_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Total gaps before consolidation"
        },
        "consolidated_gap_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Total gaps after consolidation"
        },
        "reduction_percentage": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Percentage reduction in gap count"
        },
        "consolidation_groups": {
          "type": "array",
          "description": "Details of each consolidation group",
          "items": {
            "type": "object",
            "required": ["group_id", "topic", "original_items", "consolidated_to"],
            "additionalProperties": false,
            "properties": {
              "group_id": {
                "type": "integer",
                "minimum": 1,
                "description": "Unique identifier for this consolidation group"
              },
              "topic": {
                "type": "string",
                "minLength": 3,
                "maxLength": 100,
                "description": "Topic name for this consolidation group"
              },
              "original_items": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                },
                "description": "Item names of original gaps in this group"
              },
              "consolidated_to": {
                "type": "string",
                "minLength": 3,
                "maxLength": 100,
                "description": "Item name of consolidated gap"
              },
              "reason": {
                "type": "string",
                "description": "Optional reason why these were consolidated together"
              }
            }
          }
        }
      }
    }
  }
}
