{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Synthesis Output Schema",
  "description": "Schema for validating Opus architect synthesizer output structure",
  "type": "object",
  "required": ["claude_md_content", "project_context_content"],
  "properties": {
    "claude_md_content": {
      "type": "string",
      "minLength": 300,
      "maxLength": 20000,
      "description": "CLAUDE.md content (30-200 lines ~ 1500-10000 chars)"
    },
    "project_context_content": {
      "type": "string",
      "minLength": 1000,
      "maxLength": 80000,
      "description": "project-context/SKILL.md content (50-800 lines ~ 2500-40000 chars)"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "claude_md_line_count": {
          "type": "integer",
          "minimum": 30,
          "maximum": 200
        },
        "project_context_line_count": {
          "type": "integer",
          "minimum": 50,
          "maximum": 800
        },
        "synthesis_model": {
          "type": "string",
          "const": "opus"
        }
      }
    }
  }
}
