{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CLAUDE.md Schema",
  "description": "Schema for validating CLAUDE.md structure and content",
  "type": "object",
  "required": ["format", "line_count", "sections"],
  "properties": {
    "format": {
      "type": "string",
      "enum": ["markdown"],
      "description": "Must be pure markdown, no JSON blocks"
    },
    "line_count": {
      "type": "integer",
      "minimum": 30,
      "maximum": 250,
      "description": "CLAUDE.md must be 30-250 lines"
    },
    "sections": {
      "type": "object",
      "required": ["title", "tech_stack", "file_placement", "commands"],
      "properties": {
        "title": {
          "type": "boolean",
          "const": true,
          "description": "Must have # Project Name header"
        },
        "tech_stack": {
          "type": "boolean",
          "const": true,
          "description": "Must have ## Tech Stack section"
        },
        "file_placement": {
          "type": "boolean",
          "const": true,
          "description": "Must have ## File Placement Guide section"
        },
        "commands": {
          "type": "boolean",
          "const": true,
          "description": "Must have ## Essential Commands section"
        }
      }
    },
    "has_json_blocks": {
      "type": "boolean",
      "const": false,
      "description": "Must NOT have raw JSON (only in code fences)"
    }
  }
}
