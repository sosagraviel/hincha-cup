  "agents": {
    "always": {
      "description": "Agents generated for EVERY project",
      "items": [
        {
          "name": "planner",
          "template": "planner.template.md",
          "model": "opus",
          "description": "Create detailed implementation plans with full architecture awareness"
        }
      ]
    },

    "per_language": {
      "description": "One implementer agent per detected language",
      "typescript": {
        "name": "implementer-typescript",
        "template": "implementer.template.md",
        "model": "sonnet",
        "description": "Implement TypeScript code following team conventions"
      },
      "javascript": {
        "name": "implementer-javascript",
        "template": "implementer.template.md",
        "model": "sonnet",
        "description": "Implement JavaScript code following team conventions"
      },
      "python": {
        "name": "implementer-python",
        "template": "implementer.template.md",
        "model": "sonnet",
        "description": "Implement Python code following team conventions"
      },
      "java": {
        "name": "implementer-java",
        "template": "implementer.template.md",
        "model": "sonnet",
        "description": "Implement Java code following team conventions"
      },
      "go": {
        "name": "implementer-go",
        "template": "implementer.template.md",
        "model": "sonnet",
        "description": "Implement Go code following team conventions"
      },
      "rust": {
        "name": "implementer-rust",
        "template": "implementer.template.md",
        "model": "sonnet",
        "description": "Implement Rust code following team conventions"
      },
      "ruby": {
        "name": "implementer-ruby",
        "template": "implementer.template.md",
        "model": "sonnet",
        "description": "Implement Ruby code following team conventions"
      },
      "php": {
        "name": "implementer-php",
        "template": "implementer.template.md",
        "model": "sonnet",
        "description": "Implement PHP code following team conventions"
      },
      "csharp": {
        "name": "implementer-csharp",
        "template": "implementer.template.md",
        "model": "sonnet",
        "description": "Implement C# code following team conventions"
      },
      "kotlin": {
        "name": "implementer-kotlin",
        "template": "implementer.template.md",
        "model": "sonnet",
        "description": "Implement Kotlin code following team conventions"
      },
      "swift": {
        "name": "implementer-swift",
        "template": "implementer.template.md",
        "model": "sonnet",
        "description": "Implement Swift code following team conventions"
      }
    },

    "frontend_only": {
      "description": "Agents only generated when frontend framework is detected",
      "items": [
        {
          "name": "visual-verifier",
          "template": "visual-verifier.template.md",
          "model": "opus",
          "description": "Visual verification and UI diff analysis"
        }
      ]
    }
  },

  "commands": {
    "always": {
      "description": "Commands copied to EVERY project",
      "items": [
        "implement-ticket.md",
        "create-sdd-ticket.md",
        "initialize-project.md"
      ]
    },

    "by_stack": {
      "description": "Commands copied based on detected stack",
      "typescript": [],
      "python": [],
      "react": [],
      "nestjs": [],
      "docker": []
    }
  },

  "template_variables": {
    "description": "Mapping from Opus synthesis JSON to template variables",

    "CLAUDE.md": {
      "PROJECT_NAME": "$.project_name",
      "PROJECT_DESCRIPTION": "$.project_description",
      "TECH_STACK_TABLE": "$.tech_stack | format_table",
      "ARCHITECTURE_PATTERN": "$.architecture.pattern",
      "ARCHITECTURE_DESCRIPTION": "$.architecture.description",
      "KEY_DIRECTORIES": "$.architecture.key_directories | format_list",
      "FILE_PLACEMENT_TABLE": "$.file_placement | format_table",
      "CMD_DEV": "$.commands.dev",
      "CMD_BUILD": "$.commands.build",
      "CMD_TEST": "$.commands.test",
      "CMD_TEST_UNIT": "$.commands.test_unit",
      "CMD_TEST_INTEGRATION": "$.commands.test_integration",
      "CMD_TEST_E2E": "$.commands.test_e2e",
      "CMD_LINT": "$.commands.lint",
      "CMD_FORMAT": "$.commands.format",
      "CMD_TYPE_CHECK": "$.commands.type_check",
      "CMD_MIGRATION_CREATE": "$.commands.migration_create",
      "CMD_MIGRATION_RUN": "$.commands.migration_run",
      "PATH_ALIASES_TABLE": "$.path_aliases | format_table",
      "CONV_FILE_NAMING": "$.conventions.file_naming",
      "CONV_COMMIT_FORMAT": "$.conventions.commit_format",
      "CONV_BRANCH_NAMING": "$.conventions.branch_naming",
      "CONV_TEST_NAMING": "$.conventions.test_naming",
      "GOTCHAS_SECTION": "$.gotchas | format_gotchas",
      "CRITICAL_FLOWS_SECTION": "$.critical_flows | format_flows",
      "REFERENCE_FILES": "$.reference_files | format_list",
      "COMMON_TASKS": "$.common_tasks | format_tasks",
      "TROUBLESHOOTING": "$.troubleshooting | format_list",
      "TIMESTAMP": "new Date().toISOString()"
    },

    "project-context-SKILL.md": {
      "PROJECT_NAME": "$.project_name",
      "PROJECT_DESCRIPTION": "$.project_description",
      "ARCHITECTURE_PATTERN": "$.architecture.pattern",
      "ARCHITECTURE_DESCRIPTION": "$.architecture.description",
      "LAYER_RESPONSIBILITIES": "$.architecture.layer_responsibilities | format_list",
      "CRITICAL_FLOWS": "$.critical_flows | format_flows_detailed",
      "NON_OBVIOUS_PATTERNS": "$.gotchas | format_patterns",
      "MULTI_FILE_PATTERNS": "$.multi_file_patterns | format_numbered_list",
      "GUARD_MIDDLEWARE_CHAIN": "$.guard_middleware_chain | format_list",
      "EVENT_DRIVEN_PATTERNS": "$.event_driven_patterns | format_list",
      "DB_NAMING_CONVENTIONS": "$.database.naming_conventions",
      "MIGRATION_WORKFLOW": "$.database.migration_workflow | format_steps",
      "TRANSACTION_PATTERNS": "$.database.transaction_patterns | format_code",
      "UNIT_TEST_PATTERNS": "$.testing.unit_patterns | format_list",
      "INTEGRATION_TEST_PATTERNS": "$.testing.integration_patterns | format_list",
      "E2E_TEST_PATTERNS": "$.testing.e2e_patterns | format_list",
      "GOTCHAS_LIST": "$.gotchas | format_numbered_list",
      "FILE_DEPENDENCIES": "$.file_dependencies | format_dependency_map",
      "ENV_VARS": "$.env_vars | format_env_table",
      "TIMESTAMP": "new Date().toISOString()"
    }
  }
}
