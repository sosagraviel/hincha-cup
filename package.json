{
  "name": "ai-agentic-framework-root",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "initialize": "pnpm -F orchestration initialize",
    "implement": "pnpm -F orchestration implement",
    "sync-framework-resources": "pnpm -F orchestration sync-framework-resources",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "test:integration": "pnpm -r test:integration",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "format": "pnpm -r format",
    "format:fix": "pnpm -r format:fix",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
