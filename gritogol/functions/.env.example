# Cloud Functions local env (copy to .env for emulators)
#
# Demo setup — these values let anyone run the project locally without any external API keys.
# Mock scores replace live football data, and moderation is bypassed so video uploads are
# auto-approved without an OpenAI key.
#
USE_MOCK_SCORES=true

# Content moderation (OpenAI omni-moderation-latest)
# Set USE_MOCK_MODERATION=true in emulators to skip OpenAI and auto-approve all videos.
# For demo mode, set OPENAI_API_KEY=false to disable moderation entirely.
USE_MOCK_MODERATION=false
# In production, set via: firebase functions:secrets:set OPENAI_API_KEY
OPENAI_API_KEY=false

# API-Football
# API_FOOTBALL_KEY=your-api-sports-key
