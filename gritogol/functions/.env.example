# Cloud Functions local env (copy to .env for emulators)
USE_MOCK_SCORES=true

# Content moderation (OpenAI omni-moderation-latest)
# Set to true in emulators to skip OpenAI and auto-approve all videos
USE_MOCK_MODERATION=true
# In production, set via: firebase functions:secrets:set OPENAI_API_KEY
# OPENAI_API_KEY=sk-...

# API-Football
# API_FOOTBALL_KEY=your-api-sports-key
