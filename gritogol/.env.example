# Firebase project configuration
# Copy this file to .env.local and fill in the values from your Firebase Console
# Project settings → General → Your apps → Web app → SDK setup and configuration

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# For local emulators, use the same projectId as .firebaserc (gritogol):
# VITE_FIREBASE_PROJECT_ID=gritogol
# VITE_USE_EMULATORS=true
# VITE_FIREBASE_API_KEY=AIzaSyDEMO_KEY_FOR_EMULATORS_ONLY
# VITE_EMULATOR_HOST=127.0.0.1   # set to your Mac's LAN IP to test from a phone

# API-Football (api-sports.io) — used by Cloud Functions syncCopaScores (never expose in VITE_*)
# Set in production: firebase functions:secrets:set API_FOOTBALL_KEY
# API_FOOTBALL_KEY=your-api-sports-key
