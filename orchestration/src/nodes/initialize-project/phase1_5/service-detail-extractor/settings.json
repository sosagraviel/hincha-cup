{
  "permissions": {
    "deny": ["${FRAMEWORK_EXCLUDED_DENY_RULES}"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Glob|Grep|Read|Edit|Write|MultiEdit|LS|Bash|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${FRAMEWORK_PATH}/orchestration/node_modules/.bin/tsx ${FRAMEWORK_PATH}/orchestration/src/nodes/initialize-project/shared/hooks/restrict-agent-paths.hook.ts"
          },
          {
            "type": "command",
            "command": "${FRAMEWORK_PATH}/orchestration/node_modules/.bin/tsx ${FRAMEWORK_PATH}/orchestration/src/nodes/initialize-project/phase1_5/service-detail-extractor/hooks/restrict-service-paths.hook.ts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "service-detail-extractor",
        "hooks": [
          {
            "type": "command",
            "command": "${FRAMEWORK_PATH}/orchestration/node_modules/.bin/tsx ${FRAMEWORK_PATH}/orchestration/src/nodes/initialize-project/phase1_5/service-detail-extractor/hooks/validate-service-detail.hook.ts"
          }
        ]
      }
    ]
  }
}
