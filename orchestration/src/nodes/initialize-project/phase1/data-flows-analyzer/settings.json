{
  "permissions": {
    "allow": ["${FRAMEWORK_AGENT_READ_ALLOW}"],
    "deny": ["${FRAMEWORK_EXCLUDED_DENY_RULES}"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Glob|Grep|Read|Edit|Write|MultiEdit|LS|Bash|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${FRAMEWORK_PATH}/orchestration/node_modules/.bin/tsx ${FRAMEWORK_PATH}/orchestration/src/nodes/initialize-project/shared/hooks/restrict-agent-paths.hook.ts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "data-flows-integrations-analyzer",
        "hooks": [
          {
            "type": "command",
            "command": "${FRAMEWORK_PATH}/orchestration/node_modules/.bin/tsx ${FRAMEWORK_PATH}/orchestration/src/nodes/initialize-project/phase1/shared/hooks/validate-analyzer-json.hook.ts"
          }
        ]
      }
    ]
  }
}
