        "reviewer": "sonnet-latest",
        "visual-verifier": "sonnet-latest",
        "structure-architecture-analyzer": {
          "alias": "sonnet-latest",
          "reasoningEffort": "low"
        },
        "tech-stack-dependencies-analyzer": {
