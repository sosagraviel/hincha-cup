  "thinkingBudgets": {
    "description": "Per-agent thinking-token cap. 0 disables extended thinking. Used by Anthropic models that honor extended thinking and by Codex's model_reasoning_effort heuristic mapping. Mechanical-extraction agents (Phase 1 analyzers) get 0; reasoning agents (synthesis) get a generous budget; everything else inherits the per-model default.",
    "byAgent": {
      "structure-architecture-analyzer": 0,
      "tech-stack-dependencies-analyzer": 0,
      "code-patterns-testing-analyzer": 0,
      "data-flows-integrations-analyzer": 0,
      "service-detail-extractor": 0,
      "question-consolidator": 0,
      "architect-synthesizer": 8000,
      "wiki-generator": 2000
    }
  },
  "providerConfig": {
    "anthropic": {
      "apiKeyEnv": "ANTHROPIC_API_KEY",
      "defaultTemperature": 0,
      "defaultMaxTokens": 4096,
      "headers": {
        "anthropic-beta": "max-tokens-3-5-sonnet-2024-07-15"
      }
    },
    "openai": {
      "apiKeyEnv": "OPENAI_API_KEY",
      "defaultTemperature": 0,
      "defaultMaxTokens": 4096,
      "baseURL": "https://api.openai.com/v1"
    },
    "google": {
      "apiKeyEnv": "GOOGLE_API_KEY",
      "defaultTemperature": 0,
      "defaultMaxTokens": 8192
    }
  }
}
