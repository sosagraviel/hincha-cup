{
  "version": "1.0.0",
  "modelAliases": {
    "sonnet-latest": {
      "provider": "anthropic",
      "modelId": "claude-sonnet-4-6",
      "description": "Latest Sonnet model - best combination of speed and intelligence (Feb 2026)",
      "capabilities": ["code", "planning", "reasoning", "extended-thinking", "adaptive-thinking"],
      "contextWindow": 1000000,
      "maxOutput": 64000,
      "knowledgeCutoff": "2025-08"
    },
    "haiku-latest": {
      "provider": "anthropic",
      "modelId": "claude-haiku-4-5-20251001",
      "description": "Fastest model with near-frontier intelligence (Oct 2025)",
      "capabilities": ["code", "quick-tasks", "extended-thinking"],
      "contextWindow": 200000,
      "maxOutput": 64000,
      "knowledgeCutoff": "2025-02"
    },
    "opus-latest": {
      "provider": "anthropic",
      "modelId": "claude-opus-4-6",
      "description": "Most intelligent model for building agents and coding (Feb 2026)",
      "capabilities": [
        "code",
        "planning",
        "reasoning",
        "advanced",
        "extended-thinking",
        "adaptive-thinking"
      ],
      "contextWindow": 1000000,
      "maxOutput": 128000,
      "knowledgeCutoff": "2025-05"
    },
    "gpt5-latest": {
      "provider": "openai",
      "modelId": "gpt-5.4",
      "description": "Latest GPT-5.4 flagship model for complex reasoning (Mar 2026)",
      "capabilities": ["code", "planning", "reasoning", "advanced"],
      "contextWindow": 1000000,
      "maxOutput": 16384
    },
    "gpt5-mini": {
      "provider": "openai",
      "modelId": "gpt-5.4-mini-2026-03-17",
      "description": "Fast GPT-5.4 mini for high-volume workloads (Mar 2026)",
      "capabilities": ["code", "quick-tasks"],
      "contextWindow": 128000,
      "maxOutput": 16384
    },
    "gemini-latest": {
      "provider": "google",
      "modelId": "gemini-3.1-pro-preview",
      "description": "Latest Gemini 3.1 Pro - most advanced reasoning model (Feb 2026)",
      "capabilities": ["code", "planning", "reasoning", "advanced"],
      "contextWindow": 1000000,
      "maxOutput": 8192
    },
    "gemini-flash": {
      "provider": "google",
      "modelId": "gemini-2.5-flash",
      "description": "Best price-performance for low-latency tasks (2026)",
      "capabilities": ["code", "reasoning"],
      "contextWindow": 1000000,
      "maxOutput": 8192
    }
  },
