{
  "hooks": {
    "Stop": [
      {
        "matcher": "analyzer",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx $CLAUDE_PROJECT_DIR/.claude/hooks/validate-analyzer-json.ts",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "question-consolidator",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx $CLAUDE_PROJECT_DIR/.claude/hooks/validate-extraction-json.ts",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
