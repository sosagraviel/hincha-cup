{
  "name": "orchestration",
  "version": "1.0.0",
  "description": "TypeScript DeepAgents orchestration for AI Agentic Framework",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "directories": {
    "test": "test"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "dev": "tsx",
    "initialize": "tsx src/cli/initialize.ts",
    "implement": "tsx src/cli/implement.ts",
    "sync-framework-resources": "tsx src/scripts/sync-framework-resources.ts",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint src/ test/ --fix",
    "format": "prettier --check src/ test/",
    "format:check": "prettier --check src/ test/",
    "format:fix": "prettier --write src/ test/"
  },
  "bin": {
    "orchestrate-init": "./src/cli/initialize.ts"
  },
  "keywords": [
    "orchestration",
    "deepagents",
    "langgraph",
    "ai",
    "agents"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.116",
    "@langchain/anthropic": "^1.3.24",
    "@langchain/core": "^1.1.33",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/langgraph": "^1.2.3",
    "@langchain/langgraph-checkpoint-sqlite": "^1.0.1",
    "@langchain/openai": "^1.3.0",
    "@openai/codex": "^0.121.0",
    "@types/pngjs": "^6.0.5",
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "deepagents": "^1.8.4",
    "fast-glob": "^3.3.2",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.8",
    "log-update": "^7.2.0",
    "ora": "^9.3.0",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "spinnies": "^0.5.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/spinnies": "^0.5.3",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.0"
  }
}
