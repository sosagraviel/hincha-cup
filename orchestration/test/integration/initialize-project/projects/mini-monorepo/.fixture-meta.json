{
  "name": "mini-monorepo",
  "shape": "gira",
  "expected_file_count_max": 130,
  "expected_source_file_count_max": 30,
  "languages": ["typescript"],
  "services_count": 5,
  "service_types_present": ["backend", "frontend", "library", "infrastructure", "cli"],
  "required_categories": {
    "ci_workflows": [".github/workflows/ci.yml", ".github/workflows/codeql.yml"],
    "husky": [".husky/pre-commit", ".husky/commit-msg", ".husky/pre-push"],
    "commitlint": ["commitlint.config.js"],
    "lint_staged": ["package.json#lint-staged"],
    "linter_config": ["eslint.config.mjs"],
    "formatter_config": ["prettier.config.mjs", ".prettierignore"],
    "editor_config": [".editorconfig"],
    "vscode": [".vscode/settings.json", ".vscode/extensions.json", ".vscode/launch.json"],
    "devcontainer": [".devcontainer/devcontainer.json"],
    "automation": ["Makefile", "scripts/setup.sh", "scripts/wait-for-postgres.sh"],
    "containers": ["docker-compose.yml", "docker-compose.production.yml"],
    "multi_stage_dockerfile": [
      "services/backend/Dockerfile.development",
      "services/backend/Dockerfile.production"
    ],
    "runtime_versions": [".nvmrc"],
    "package_manager_config": [".npmrc", ".pnpmrc", "pnpm-workspace.yaml"],
    "lockfiles": ["pnpm-lock.yaml"],
    "env_templates": [".env.development.example", ".env.testing.example"],
    "test_configs": [
      "services/backend/jest.config.mjs",
      "services/backend/jest.integration.config.ts",
      "services/web-frontend/vitest.config.ts",
      "services/web-frontend/playwright.config.ts",
      "e2e/playwright.config.ts"
    ],
    "real_tests": [
      "services/backend/src/users/users.spec.ts",
      "services/backend/src/auth/auth.spec.ts",
      "services/web-frontend/src/__tests__/api-client.test.ts",
      "services/shared/src/utils/format-date.spec.ts",
      "e2e/tests/login.spec.ts"
    ],
    "migrations": ["services/backend/src/migrations/0001-initial-schema.ts"],
    "openapi": ["services/backend/openapi.yaml"],
    "docs": [
      "README.md",
      "CONTRIBUTING.md",
      "docs/getting-started.md",
      "docs/architecture-overview.md",
      "ANALYSIS.md"
    ],
    "github_governance": [
      ".github/CODEOWNERS",
      ".github/pull_request_template.md",
      ".github/dependabot.yml",
      ".github/ISSUE_TEMPLATE/bug_report.md",
      ".github/ISSUE_TEMPLATE/feature_request.md"
    ],
    "framework_markers": [".code-review-graphignore", ".mcp.json"],
    "license_security": ["LICENSE", "SECURITY.md", "CHANGELOG.md"]
  }
}
