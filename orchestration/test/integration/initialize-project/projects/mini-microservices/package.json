{
  "name": "mini-microservices",
  "version": "0.1.0",
  "private": true,
  "description": "Plan v5 fixture — polyglot microservices (Go + .NET + Python + Node + protobuf).",
  "scripts": {
    "lint": "make lint",
    "test": "make test",
    "format": "prettier --write '**/*.{json,md,yml,yaml}'",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.3.0"
  },
  "lint-staged": {
    "*.go": ["gofmt -w"],
    "*.py": ["poetry run black", "poetry run ruff check --fix"],
    "*.cs": ["dotnet format --include"],
    "*.{js,ts}": ["prettier --write"]
  }
}
