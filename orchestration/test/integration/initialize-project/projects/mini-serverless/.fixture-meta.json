{
  "name": "mini-serverless",
  "shape": "clasp",
  "expected_file_count_max": 140,
  "expected_source_file_count_max": 30,
  "languages": ["typescript", "javascript", "python"],
  "services_count": 7,
  "service_types_present": ["serverless", "frontend", "library", "cli"],
  "required_categories": {
    "ci_workflows": [".github/workflows/ci.yml", ".github/workflows/deploy.yml"],
    "husky": [".husky/pre-commit", ".husky/commit-msg", ".husky/pre-push"],
    "pre_commit_python": [".pre-commit-config.yaml"],
    "commitlint": ["commitlint.config.js"],
    "lint_staged": ["package.json#lint-staged"],
    "linter_config": ["eslint.config.mjs", "pyproject.toml"],
    "formatter_config": ["prettier.config.mjs", ".prettierignore"],
    "editor_config": [".editorconfig"],
    "automation": [
      "Makefile",
      "scripts/sanity_check.sh",
      "linter.sh",
      "js_linter.sh",
      "py_linter.sh"
    ],
    "containers": ["local-emulator/docker-compose.yml", "devops/docker-compose.installer.yml"],
    "multi_stage_dockerfile": ["web/Dockerfile"],
    "runtime_versions": [".nvmrc", ".python-version", ".tool-versions"],
    "package_manager_config": [".npmrc", ".pnpmrc", "pnpm-workspace.yaml"],
    "lockfiles": ["pnpm-lock.yaml", "functions/python/poetry.lock"],
    "env_templates": [".env.development.example", "env.json.template"],
    "firebase": [
      "firebase/firebase.json",
      "firebase/firestore.rules",
      "firebase/firestore.indexes.json",
      "firebase/storage.rules",
      ".firebaserc"
    ],
    "gcloud": ["cloudbuild.yaml", ".gcloudignore"],
    "per_service_gcloudignore": [
      "firebase/.gcloudignore",
      "functions/js/.gcloudignore",
      "functions/python/.gcloudignore",
      "web/.gcloudignore"
    ],
    "test_configs": [
      "firebase/jest.config.js",
      "functions/js/jest.config.ts",
      "web/vitest.config.ts",
      "web/playwright.config.ts",
      "web/cypress.config.ts"
    ],
    "real_tests": [
      "firebase/functions/tests/auth.test.js",
      "functions/js/tests/index.test.ts",
      "functions/python/unit_tests/tests_level0/audit/test_audit.py",
      "web/tests/e2e/smoke.spec.ts",
      "cypress/e2e/smoke.cy.ts"
    ],
    "python_conftest": ["functions/python/conftest.py"],
    "babel_legacy_config": ["firebase/babel.config.cjs"],
    "openapi": ["api/openapi.yaml", "api/account-details.rest"],
    "docs": [
      "README.md",
      "CONTRIBUTING.md",
      "docs/getting-started.md",
      "docs/deploy.md",
      "docs/env-management.md"
    ],
    "github_governance": [
      ".github/pull_request_template.md",
      ".github/dependabot.yml",
      ".github/ISSUE_TEMPLATE/bug_report.md"
    ],
    "license_security": ["LICENSE"],
    "devops_shell_scripts": [
      "devops/scripts/check-requirements.sh",
      "devops/scripts/install.sh",
      "devops/scripts/ping.firebase.sh",
      "devops/scripts/pre-deploy.js",
      "devops/scripts/post-deploy.js"
    ],
    "doppler": [
      "env-handlers/doppler_secrets.sh",
      "env-handlers/change_env.sh"
    ]
  }
}
