# ==============================================================================
# PROJECT CONFIGURATION
# ==============================================================================
PROJECT_NAME=gira
VENDOR_NAME=gira
NODE_ENV=testing

# ==============================================================================
# API/BACKEND CONFIGURATION
# ==============================================================================
API_NAME=gira_api
API_PREFIX=api/v1
API_PORT=3050
CLIENT_URL=http://localhost
AWS_REGION=us-east-1
AWS_BUCKET_NAME=gira-attachments
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=admin

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
DB_TYPE=postgres
DB_HOST=db
DB_PORT=5432
DB_USER=db_user
DB_PASSWORD=example
DB_NAME=gira_db
DB_LOGGING=true
DB_MIGRATIONS_RUN=true
DB_SYNCHRONIZE=false

# ==============================================================================
# REDIS CONFIGURATION
# ==============================================================================
REDIS_HOST=redis
REDIS_PORT=6379

# ==============================================================================
# KEYCLOAK CONFIGURATION
# ==============================================================================

# --- Server Settings ---
KEYCLOAK_HTTP_PORT=7080
KEYCLOAK_HTTPS_PORT=7443

# --- URLs ---
KEYCLOAK_INTERNAL_URL=http://keycloak:7080
KEYCLOAK_EXTERNAL_URL=http://localhost:7080

# --- Admin Credentials ---
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# --- Realm & Client Settings ---
KEYCLOAK_REALM=gira
KEYCLOAK_CLIENT_ID=web-frontend
KEYCLOAK_BACKEND_CLIENT_ID=backend-api
KEYCLOAK_BACKEND_CLIENT_SECRET=backend-api-secret

# --- Test Client Configuration ---
KEYCLOAK_TEST_CLIENT_NAME=postman
KEYCLOAK_TEST_CLIENT_SECRET=dumbsecret

# --- Application URLs ---
ROOT_URL=http://localhost:2712
ADMIN_URL=http://localhost:2712
BASE_URL=http://localhost:2712
REDIRECT_URIS=http://localhost:2712/*
WEB_ORIGINS=http://localhost:2712

# ==============================================================================
# EMAIL/SMTP CONFIGURATION
# ==============================================================================
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@test.com
WELCOME_EMAIL_SUBJECT="Welcome to Gira"
SUPPORT_EMAIL=support@gira.dev

# ==============================================================================
# FRONTEND CONFIGURATION
# ==============================================================================
VITE_KEYCLOAK_EXTERNAL_URL=http://localhost:7080
VITE_KEYCLOAK_REALM=gira
VITE_KEYCLOAK_CLIENT_ID=web-frontend
VITE_WEBSOCKET_URL=ws://localhost:3050
VITE_API_URL=http://localhost:3050
